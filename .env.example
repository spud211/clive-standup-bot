# Teams meeting URL (required for direct mode)
TEAMS_MEETING_URL=https://teams.microsoft.com/l/meetup-join/...

# Bot display name shown in the meeting
BOT_DISPLAY_NAME=Clive: Standup AI

# Run browser headless (true for production, false for local dev)
HEADLESS=false

# Name pattern for who always goes last in standup order (substring match, case-insensitive)
LAST_SPEAKER_NAME=Kinder

# Language for bot messages and triggers: "en" (English) or "fr" (French)
LANGUAGE=en

# Run mode: "direct" (single meeting from env) or "api" (REST server)
MODE=direct

# REST API settings (Phase 1.5+)
API_PORT=3002
API_HOST=0.0.0.0

# Text-to-speech settings (Phase 2)
TTS_ENABLED=true
TTS_BACKEND=say           # "say" (macOS) or "espeak" (Linux)
TTS_VOICE=                # Voice name for English (e.g. "Jamie (Enhanced)" for say). Leave blank for default.
TTS_VOICE_FR=Thomas       # Voice name for French (e.g. "Thomas", "Audrey"). Leave blank for default.
TTS_RATE=                 # Speech rate (words per minute for say, speed for espeak). Leave blank for default.

# Virtual camera (Phase 2.4+)
AVATAR_IMAGE_PATH=assets/clive-avatar.png   # Path to static avatar image. Leave blank to keep camera off.
AVATAR_VIDEO_PATH=                          # Path to looping video (MP4/WebM). Takes priority over image. Leave blank for static image.

# Audio device for TTS output (routed into browser as mic via virtual audio)
AUDIO_DEVICE=BlackHole 2ch   # macOS: install BlackHole and set as system input. Leave blank to disable TTS audio.
